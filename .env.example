# Logo.dev API keys
# Get from: https://logo.dev/dashboard
LOGODEV_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxx
VITE_LOGODEV_PUBLISHABLE_KEY=pk_xxxxxxxxxxxxxxxxxxxxx

# Admin credentials - CRITICAL
# Set via environment variables in your deployment platform (Vercel, etc.)
# DO NOT put actual values in .env files
# Minimum 8 characters, use strong passwords
# ADMIN_NAME=Your Name
# ADMIN_EMAIL=your-email@company.com
# ADMIN_PASSWORD=your-strong-password-here

# Firebase Client Configuration
# Get from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxx

# Firebase Admin SDK (server-side only) - CRITICAL
# ⚠️ STORE THESE ONLY IN DEPLOYMENT PLATFORM SECRETS, NEVER IN .env FILES
# Get from Firebase Console > Service Accounts > Create new key (JSON)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# Nodemailer Configuration (for sending emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password

# Application Configuration
NODE_ENV=development
VITE_API_URL=http://localhost:5173/api

# Deployment Platform
# For Vercel deployments, set these in Vercel project settings
# VERCEL_ENV=development
# VERCEL_GIT_REPO_OWNER=your-username
# VERCEL_GIT_REPO_SLUG=your-repo
